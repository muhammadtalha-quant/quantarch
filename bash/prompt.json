{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#928374",
          "template": "\u256d\u2500"
        },
        {
          "type": "os",
          "style": "powerline",
          "foreground": "#1793d1",
          "background": "#333333",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1d2021",
          "background": "#83a598",
          "template": " \uf07c {{ .Path }} ",
          "options": {
            "style": "agnoster_short",
            "max_depth": 2
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1d2021",
          "background": "#a6e3a1",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fabd2f{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#fb4934{{ end }}",
            "{{ if gt .Ahead 0 }}#d3869b{{ end }}",
            "{{ if gt .Behind 0 }}#d3869b{{ end }}"
          ],
          "template": " \ue0a0 {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "options": {
            "branch_icon": "",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "#1d2021",
          "background": "#d3869b",
          "template": " \uf252 {{ .FormattedMs }} ",
          "options": {
            "threshold": 500,
            "style": "round"
          }
        },
        {
          "type": "status",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "#1d2021",
          "background": "#b8bb26",
          "background_templates": ["{{ if gt .Code 0 }}#fb4934{{ end }}"],
          "template": " {{ if gt .Code 0 }}\uf00d {{ .Code }}{{ else }}\uf00c{{ end }} "
        },
        {
          "type": "time",
          "style": "powerline",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "foreground": "#ebdbb2",
          "background": "#3c3836",
          "template": " \uf017 {{ .CurrentDate | date \"15:04:05\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#928374",
          "template": "\u2570\u2500"
        },
        {
          "type": "root",
          "style": "plain",
          "foreground": "#fb4934",
          "template": "\uf0e7 "
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#83a598",
          "template": "\u276f "
        }
      ]
    }
  ],
  "version": 4,
  "final_space": true
}
